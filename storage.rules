rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Enable public uploads for candidates (documents, CUL, etc)
    match /candidates/documents/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Default rule for all other paths: requires auth
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
